# Agentic Hackathon Arc — copy to `.env` (never commit real keys)

# --- Quick checklist (names the app reads) ---
# thirdweb (server):     THIRDWEB_SECRET_KEY, optional THIRDWEB_SERVER_WALLET_ADDRESS
# thirdweb + browser:    X402_FACILITATOR=thirdweb  and  VITE_X402_FACILITATOR=thirdweb
# Circle Modular (UI):   VITE_CIRCLE_CLIENT_KEY  (Vite must restart after changes)
# Circle Gateway x402:   no API key — wallet + USDC on Arc; optional VITE_GATEWAY_* below
# Featherless (server):  FEATHERLESS_API_KEY  for POST /api/neighbourhood/insights/summary

# Core server
PORT=8787
ARC_TESTNET=true

# x402 payments (Arc Testnet)
# Facilitator: `circle` (default, Circle Gateway batching) or `thirdweb` (settlePayment + thirdweb dashboard).
# X402_FACILITATOR=circle
# thirdweb — https://portal.thirdweb.com/x402/facilitator
# THIRDWEB_SECRET_KEY=
# Server wallet from thirdweb dashboard (executes settlements); defaults to X402_SELLER_ADDRESS if unset
# THIRDWEB_SERVER_WALLET_ADDRESS=0x7Ebd642eBEb9196193125fdC3B86E363E7bF82E0
# Optional: simulated | submitted | confirmed (thirdweb settle wait)
# THIRDWEB_SETTLE_WAIT_UNTIL=submitted
# Seller/recipient wallet for payment settlement.
X402_SELLER_ADDRESS=0x742d35Cc6634c0532925a3b844bC9e7595F8fE00
# Optional overrides (usually leave as-is)
X402_DECIMALS=6
# X402_CURRENCY=
# PAYMENT_MODE=mock
# NHS payment gate: enforce x402 on NHS write routes. Set false for local dev without wallet pay.
NHS_ENABLE_PAYMENT_GATE=true

# Browser default for neighbourhood + OpenEHR paid routes (overridable in UI via localStorage)
# VITE_X402_FACILITATOR=thirdweb
# Requests send header X-X402-Facilitator: circle | thirdweb (defaults from X402_FACILITATOR when omitted).
# THIRDWEB_SECRET_KEY required on server when choosing Thirdweb. NHS /api/nhs/* routes always use Circle.

# Optional: browser session deposit cap (human units)
# VITE_X402_SESSION_MAX_DEPOSIT=50

# Circle Gateway (browser): auto top-up before x402 paid requests
# VITE_GATEWAY_MIN_AVAILABLE_USDC=0.5
# VITE_GATEWAY_TOPUP_USDC=1
# VITE_GATEWAY_SKIP_AUTO_DEPOSIT=true

# Notes:
# - Circle Faucet for Arc Testnet: https://faucet.circle.com/
# - No Circle API key is required for the public faucet flow.

# Circle Modular (browser — Neighbourhood insights panel loads SDK with this)
# VITE_CIRCLE_CLIENT_KEY=
# Localhost default: same-origin POST /api/circle-modular (avoids CORS on direct SDK). Restart Vite after changes.
# Optional: VITE_CIRCLE_MODULAR_DIRECT=1  — browser calls https://modular-sdk.circle.com directly (needs Circle CORS).
# Optional: VITE_CIRCLE_MODULAR_MOCK=1  — demo only; skips live modular-sdk (Cloudflare 403 from Node is upstream).
# Optional: CIRCLE_MODULAR_SDK_URL=

# Optional Snowstorm (SNOMED CT) — https://github.com/IHTSDO/snowstorm — docker-compose.snowstorm.yml
# SNOWSTORM_URL=http://localhost:8081

# EHRbase (OpenEHR ITS REST / AQL) — start stack first: npm run ehrbase:up
# Defaults match docker-compose.ehrbase.yml (ehrbase-user / SuperSecretPassword).
# EHRBASE_BASE_URL=http://localhost:8080/ehrbase
# EHRBASE_USER=ehrbase-user
# EHRBASE_PASSWORD=SuperSecretPassword

# Featherless (server — paid LLM summary route)
# FEATHERLESS_API_KEY=
# FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
# (Meta Llama models often need Hugging Face linked in Featherless — see model page if you get model_gated_needs_oauth.)
# FEATHERLESS_API_URL=https://api.featherless.ai/v1/chat/completions
# HES ingest: HES_SAMPLE_DIR=/path/to/artificial_hes_ae_202302_v1_sample
